{% extends 'base.html.twig' %}

{% block title %}Project Dashboard
{% endblock %}

{% block body %}
	<div class="dashboard-wrapper">
		<div class="dashboard-card">

			<h1>🎉 Congratulations! 🎉</h1>
			<h2>Platform Technology Student</h2>

			<p class="lead">
				You have successfully run this Symfony application inside Docker and other containers!
			</p>

			<div class="badge badge-header">
				✅ Docker Compose &amp; Multi-Container Environment Running
			</div>

			<div class="badge">
				{% if db_working %}
					✅ Database connection is working
				{% else %}
					❌ Database connection failed
				{% endif %}
			</div>

			<p class="footer-text">
				Welcome to your platform technology dashboard.<br>
				Enjoy exploring Docker Compose and containerized development!
			</p>

		</div>
	</div>
{% endblock %}
